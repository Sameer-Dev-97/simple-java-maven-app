pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                bat 'mvn -B -DskipTests clean package'
            }
        }

        stage('Test') {
            steps {
                bat 'mvn test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('Deliver') {
            steps {
                echo 'Deliver stage executed'
                // Add deployment commands here later
            }
        }

        stage('Complete') {
            steps {
                echo 'Job Complete!'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Oh sorry! Pipeline failed!'
        }
    }
}
